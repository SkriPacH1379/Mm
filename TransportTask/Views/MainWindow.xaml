<Window x:Class="TransportTask.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Транспортная задача" 
        Height="850" 
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- MENU + TOOLBAR -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="Файл">
                    <MenuItem Header="Загрузить JSON..." Click="MenuLoadJson_Click"/>
                    <MenuItem Header="Сохранить результат..." Click="MenuSave_Click"/>
                    <Separator/>
                    <MenuItem Header="Выход" Click="MenuExit_Click"/>
                </MenuItem>
                <MenuItem Header="Методы">
                    <MenuItem Header="Северо-западный угол" Click="MenuNorthWest_Click"/>
                    <MenuItem Header="Минимальный элемент" Click="MenuMinimumCost_Click"/>
                </MenuItem>
                <MenuItem Header="Справка" Click="MenuAbout_Click"/>
            </Menu>

            <ToolBar Margin="0,4,0,0">
                <Button Click="BtnLoadJson_Click" Style="{StaticResource MainButton}" ToolTip="Загрузить JSON">📂 Загрузить</Button>
                <Button Click="BtnSave_Click" Style="{StaticResource MainButton}" ToolTip="Сохранить">💾 Сохранить</Button>
                <Separator/>
                <Button Click="BtnNorthWest_Click" Style="{StaticResource MainButton}">▶ Северо-западный</Button>
                <Button Click="BtnMinimumCost_Click" Style="{StaticResource MainButton}">▶ Минимальный элемент</Button>
                <Button Click="BtnClear_Click" Style="{StaticResource MainButton}">🧹 Очистить</Button>
                <Button Click="BtnLoadExample_Click" Style="{StaticResource MainButton}"> 📋 Пример данных </Button>
            </ToolBar>
        </DockPanel>

        <!-- Параметры -->
        <GroupBox Grid.Row="1" Header="Параметры задачи" Style="{StaticResource MainGroupBox}">
            <StackPanel Orientation="Horizontal" Margin="10">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Поставщики" Style="{StaticResource TextStyle}"/>
                    <TextBox x:Name="tbRows" Width="100" Text="3" Style="{StaticResource MainTextBox}" PreviewTextInput="NumberValidation"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Потребители" Style="{StaticResource TextStyle}"/>
                    <TextBox x:Name="tbCols" Width="100" Text="4" Style="{StaticResource MainTextBox}" PreviewTextInput="NumberValidation"/>
                </StackPanel>
                <Button Content="Создать таблицы" Margin="30,0,0,0" Click="BtnCreateGrids_Click" Style="{StaticResource MainButton}" Height="36"/>
            </StackPanel>
        </GroupBox>

        <!-- Матрица стоимости -->
        <GroupBox Grid.Row="2" Header="Матрица стоимостей" Style="{StaticResource MainGroupBox}">
            <DataGrid x:Name="dgCosts" AutoGenerateColumns="False" Margin="5" Height="220" CanUserAddRows="False" CanUserDeleteRows="False"/>
        </GroupBox>

        <!-- Запасы и Потребности -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="Запасы поставщиков" Style="{StaticResource MainGroupBox}">
                <DataGrid x:Name="dgSupply" AutoGenerateColumns="False" Height="140" Margin="5"/>
            </GroupBox>
            <GroupBox Grid.Column="1" Header="Потребности потребителей" Style="{StaticResource MainGroupBox}">
                <DataGrid x:Name="dgDemand" AutoGenerateColumns="False" Height="140" Margin="5"/>
            </GroupBox>
        </Grid>

        <!-- Результат -->
        <GroupBox Grid.Row="4" Header="Результат" Style="{StaticResource MainGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="tbResult" Style="{StaticResource ResultTextBox}" Margin="5"/>
                <TextBlock x:Name="tbTotalCost" Grid.Row="1" Margin="10" FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}"/>
            </Grid>
        </GroupBox>

        <!-- StatusBar -->
        <StatusBar Grid.Row="5" Background="#F1F5F9">
            <TextBlock x:Name="statusText" Text="Готов" Margin="10,4"/>
        </StatusBar>
    </Grid>
</Window>